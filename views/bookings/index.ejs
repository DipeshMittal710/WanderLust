<% layout('layouts/boilerplate') %>

<section class="host-form-page">
    <div class="host-form-intro">
        <p class="eyebrow">Your trips</p>
        <h1>Bookings</h1>
        <p>Everything you've reserved through WanderLust, in one place.</p>
    </div>

    <% if (bookings.length === 0) { %>
        <p class="text-muted">You haven't booked anything yet. <a href="/listings">Start exploring stays</a>.</p>
    <% } else { %>
        <div class="trip-list">
            <% bookings.forEach(booking => { %>
                <%
                  const listing = booking.listing;
                  const isPast = new Date(booking.checkOut) < new Date();
                  const checkInStr = new Date(booking.checkIn).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
                  const checkOutStr = new Date(booking.checkOut).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
                  const listingImages = listing
                    ? ((listing.images && listing.images.length) ? listing.images : (listing.image && listing.image.url ? [listing.image] : []))
                    : [];
                  const tripImageUrl = listingImages[0]
                    ? listingImages[0].url
                    : "https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=800&q=70";
                %>
                <article class="trip-card">
                    <img src="<%= tripImageUrl %>" alt="<%= listing ? listing.title : 'Listing removed' %>">
                    <div class="trip-card-body">
                        <div class="trip-card-heading">
                            <div>
                                <h3>
                                    <% if (listing) { %>
                                        <a href="/listings/<%= listing._id %>"><%= listing.title %></a>
                                    <% } else { %>
                                        Listing no longer available
                                    <% } %>
                                </h3>
                                <p class="text-muted">
                                    <%= listing ? [listing.location, listing.country].filter(Boolean).join(", ") : "This stay was removed by its host" %>
                                </p>
                            </div>
                            <span class="trip-status <%= isPast ? 'trip-status-past' : 'trip-status-upcoming' %>">
                                <%= isPast ? "Completed" : "Upcoming" %>
                            </span>
                        </div>
                        <p><%= checkInStr %> &rarr; <%= checkOutStr %> &middot; <%= booking.guests %> guest<%= booking.guests === 1 ? '' : 's' %></p>
                        <p class="trip-total"><b>&#8377;<%= booking.totalPrice.toLocaleString('en-IN') %></b> total</p>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } %>
</section>
