<% layout('layouts/boilerplate') %>

<%
  const categories = [
    { name: "All", icon: "fa-solid fa-border-all" },
    { name: "Trending", icon: "fa-solid fa-fire" },
    { name: "Rooms", icon: "fa-solid fa-bed" },
    { name: "Iconic Cities", icon: "fa-solid fa-mountain-city" },
    { name: "Mountain", icon: "fa-solid fa-mountain" },
    { name: "Castles", icon: "fa-brands fa-fort-awesome" },
    { name: "Arctic", icon: "fa-regular fa-snowflake" },
    { name: "Camping", icon: "fa-solid fa-campground" },
    { name: "Farms", icon: "fa-solid fa-cow" },
    { name: "Amazing Pools", icon: "fa-solid fa-person-swimming" },
    { name: "Domes", icon: "fa-solid fa-igloo" },
    { name: "Boats", icon: "fa-solid fa-sailboat" }
  ];
  const selectedCategory = locals.activeCategory || "All";
  const activeFilters = locals.filters || {};
  const activeAmenities = activeFilters.amenities || [];
  const savedListingIds = locals.savedListingIds || [];
  const amenityOptions = [
    "Wifi", "Free parking", "Kitchen", "Air conditioning",
    "Self check-in", "Swimming pool", "TV", "Pet friendly"
  ];
%>

<section class="explore-hero">
  <div class="explore-hero-copy">
    <p class="eyebrow">WanderLust stays</p>
    <h1>Find homes that feel ready for the trip.</h1>
    <p>
      Search hand-picked villas, cabins, beach houses, city lofts, and weekend escapes.
    </p>
  </div>

  <form class="hero-search" action="/listings" method="GET">
    <label>
      <span>Destination</span>
      <input
        type="search"
        name="q"
        placeholder="Search by city, country, or category"
        value="<%= locals.searchQuery || '' %>"
      >
    </label>

    <label>
      <span>Check in</span>
      <input type="text" value="Add dates" readonly>
    </label>

    <label>
      <span>Guests</span>
      <input type="text" value="Add guests" readonly>
    </label>

    <button type="submit">
      <i class="fa-solid fa-magnifying-glass"></i>
      Search
    </button>
  </form>
</section>

<section class="market-strip" aria-label="Marketplace highlights">
  <div>
    <i class="fa-solid fa-shield-heart"></i>
    <span>Verified stays</span>
  </div>
  <div>
    <i class="fa-solid fa-calendar-check"></i>
    <span>Instant booking flow</span>
  </div>
  <div>
    <i class="fa-solid fa-indian-rupee-sign"></i>
    <span>Transparent pricing</span>
  </div>
</section>

<section class="filter-bar">
  <div id="filters" class="filter-scroll">
    <% categories.forEach(category => { %>
      <a
        class="filter-chip <%= selectedCategory === category.name ? 'active' : '' %>"
        href="/listings?category=<%= encodeURIComponent(category.name) %>"
      >
        <i class="<%= category.icon %>"></i>
        <span><%= category.name %></span>
      </a>
    <% }) %>
  </div>

  <div class="tax-toggle">
    <div class="form-check form-switch">
      <input
        class="form-check-input"
        type="checkbox"
        role="switch"
        id="switchCheckDefault"
      >
      <label class="form-check-label" for="switchCheckDefault">
        Show total after taxes
      </label>
    </div>
  </div>
</section>

<section class="advanced-filters">
  <details>
    <summary><i class="fa-solid fa-sliders"></i> More filters</summary>

    <form method="GET" action="/listings" class="filter-form">
      <input type="hidden" name="q" value="<%= locals.searchQuery || '' %>">
      <input type="hidden" name="category" value="<%= selectedCategory !== 'All' ? selectedCategory : '' %>">

      <div class="filter-row">
        <label>
          <span>Min price</span>
          <input type="number" name="minPrice" min="0" value="<%= activeFilters.minPrice %>" placeholder="\u20B90">
        </label>
        <label>
          <span>Max price</span>
          <input type="number" name="maxPrice" min="0" value="<%= activeFilters.maxPrice %>" placeholder="Any">
        </label>
        <label>
          <span>Guests</span>
          <input type="number" name="guests" min="1" value="<%= activeFilters.guests %>" placeholder="Any">
        </label>
        <label>
          <span>Min rating</span>
          <select name="minRating">
            <option value="">Any</option>
            <option value="4.5" <%= activeFilters.minRating === '4.5' ? 'selected' : '' %>>4.5+</option>
            <option value="4" <%= activeFilters.minRating === '4' ? 'selected' : '' %>>4+</option>
            <option value="3" <%= activeFilters.minRating === '3' ? 'selected' : '' %>>3+</option>
          </select>
        </label>
        <label>
          <span>Country</span>
          <input type="text" name="country" value="<%= activeFilters.country %>" placeholder="Any">
        </label>
        <label>
          <span>City</span>
          <input type="text" name="city" value="<%= activeFilters.city %>" placeholder="Any">
        </label>
      </div>

      <div class="filter-amenities">
        <span class="filter-amenities-label">Amenities</span>
        <div class="filter-amenities-list">
          <% amenityOptions.forEach(name => { %>
            <label class="filter-chip-check">
              <input type="checkbox" name="amenities" value="<%= name %>" <%= activeAmenities.includes(name) ? "checked" : "" %>>
              <span><%= name %></span>
            </label>
          <% }) %>
        </div>
      </div>

      <div class="filter-actions">
        <button type="submit" class="btn btn-dark">Apply filters</button>
        <a href="/listings" class="btn btn-outline-dark">Clear all</a>
      </div>
    </form>
  </details>
</section>

<section class="listing-toolbar">
  <div>
    <p class="eyebrow"><%= locals.searchQuery ? 'Search results' : selectedCategory + ' homes' %></p>
    <h2>
      <% if (locals.searchQuery) { %>
        Stays matching "<%= locals.searchQuery %>"
      <% } else { %>
        Explore stays
      <% } %>
    </h2>
  </div>

  <div class="toolbar-stats">
    <span><%= (listings || []).length %> stays</span>
    <span>Flexible cancellation picks</span>
  </div>
</section>

<% if (!listings || listings.length === 0) { %>
  <section class="empty-state">
    <i class="fa-regular fa-compass"></i>
    <h3>No stays found</h3>
    <p>Try another city, category, or country to discover more homes.</p>
    <a href="/listings" class="btn btn-dark">Clear search</a>
  </section>
<% } else { %>
  <section class="listing-grid" aria-label="Available stays">
    <% listings.forEach((listing, index) => { %>
      <%
        const reviews = listing.reviews || [];
        const reviewCount = reviews.length;
        const ratingTotal = reviews.reduce((sum, review) => sum + (review.rating || 0), 0);
        const averageRating = reviewCount ? (ratingTotal / reviewCount).toFixed(2) : "New";
        const guests = listing.maxGuests || 2;
        const beds = Math.max(1, Math.ceil(guests / 2));
        const locationLine = [listing.location, listing.country].filter(Boolean).join(", ");
        const cardImageList = (listing.images && listing.images.length)
          ? listing.images
          : (listing.image && listing.image.url ? [listing.image] : []);
        const imageUrl = cardImageList[0]
          ? cardImageList[0].url
          : "https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=800&q=70";
        const isGuestFavorite = reviewCount >= 2 || index % 4 === 0;
        const isSaved = savedListingIds.includes(listing._id.toString());
      %>

      <article class="stay-card">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="stay-card-image">
            <img src="<%= imageUrl %>" alt="<%= listing.title %>">
            <% if (isGuestFavorite) { %>
              <span class="guest-favorite-badge">Guest favorite</span>
            <% } %>
          </div>

          <div class="stay-card-body">
            <div class="stay-card-heading">
              <div>
                <h3><%= listing.title %></h3>
                <p><%= locationLine %></p>
                <p class="hosted-by text-muted">Hosted by <%= (listing.owner && listing.owner.username) ? listing.owner.username : "WanderLust host" %></p>
              </div>
              <span class="rating-pill">
                <i class="fa-solid fa-star"></i>
                <%= averageRating %>
              </span>
            </div>

            <div class="stay-meta">
              <span><%= guests %> guest<%= guests === 1 ? '' : 's' %></span>
              <span><%= beds %> bedroom<%= beds === 1 ? '' : 's' %></span>
              <% if (listing.category) { %>
                <span><%= listing.category %></span>
              <% } %>
            </div>

            <div class="stay-card-footer">
              <p>
                <span class="base-price">
                  <b>&#8377;<%= listing.price.toLocaleString('en-IN') %></b> night
                </span>
                <span class="tax-price">
                  <b>&#8377;<%= Math.round(listing.price * 1.30).toLocaleString('en-IN') %></b> night
                </span>
              </p>
              <small><%= reviewCount %> reviews</small>
            </div>
          </div>
        </a>

        <button
          class="save-stay-btn <%= isSaved ? 'is-saved' : '' %>"
          type="button"
          data-listing-id="<%= listing._id %>"
          aria-label="Save <%= listing.title %>"
        >
          <i class="<%= isSaved ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
        </button>
      </article>
    <% }) %>
  </section>
<% } %>
