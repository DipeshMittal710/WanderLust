<% layout('layouts/boilerplate') %>

<%
    const reviews = listing.reviews || [];
    const reviewCount = reviews.length;
    const ratingTotal = reviews.reduce((sum, review) => sum + (review.rating || 0), 0);
    const averageRating = reviewCount ? (ratingTotal / reviewCount).toFixed(2) : "New";
    const nightlyPrice = listing.price || 0;
    const serviceFee = Math.round(nightlyPrice * 0.12);
    const taxes = Math.round(nightlyPrice * 0.18);
    const oneNightTotal = nightlyPrice + serviceFee + taxes;
    const locationLine = [listing.location, listing.country].filter(Boolean).join(", ");
    const imageList = (listing.images && listing.images.length)
        ? listing.images
        : (listing.image && listing.image.url ? [listing.image] : []);
    const fallbackImageUrl = "https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=1200&q=70";
    const imageUrl = imageList[0] ? imageList[0].url : fallbackImageUrl;
    const photoSlots = [0, 1, 2, 3].map(i => imageList[i] ? imageList[i].url : imageUrl);
    const extraPhotoCount = Math.max(0, imageList.length - 4);
    const hostName = listing.owner && listing.owner.username ? listing.owner.username : "WanderLust host";
    const guests = listing.maxGuests || 2;
    const bedrooms = Math.max(1, Math.ceil(guests / 2));
    const hasCoordinates = listing.geometry
        && listing.geometry.coordinates
        && listing.geometry.coordinates.length === 2;
    const amenityIcons = {
        "Wifi": "fa-solid fa-wifi",
        "Free parking": "fa-solid fa-car",
        "Kitchen": "fa-solid fa-kitchen-set",
        "Air conditioning": "fa-solid fa-snowflake",
        "Self check-in": "fa-solid fa-key",
        "Safety essentials": "fa-solid fa-shield-heart",
        "Swimming pool": "fa-solid fa-person-swimming",
        "TV": "fa-solid fa-tv",
        "Washer": "fa-solid fa-shirt",
        "Workspace": "fa-solid fa-laptop",
        "Pet friendly": "fa-solid fa-paw",
        "Breakfast included": "fa-solid fa-mug-saucer"
    };
    const amenities = ((listing.amenities && listing.amenities.length) ? listing.amenities : [])
        .map(name => ({ icon: amenityIcons[name] || "fa-solid fa-circle-check", label: name }));

    const isOwnerOfListing = !!(currUser && listing.owner && currUser._id.equals(listing.owner._id));

    const fmtDate = (d) => new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });

    const bookedRangeList = locals.bookedRanges || [];
    const blockedDateList = locals.blockedDates || [];

    const unavailableRanges = [
        ...bookedRangeList.map(r => ({ start: r.start, end: r.end })),
        ...blockedDateList.map(b => ({ start: b.startDate, end: b.endDate }))
    ];
%>

<section class="listing-detail-heading">
    <div>
        <h1><%= listing.title %></h1>
        <div class="detail-subline">
            <span><i class="fa-solid fa-star"></i> <%= averageRating %></span>
            <span><%= reviewCount %> reviews</span>
            <span><%= locationLine %></span>
        </div>
    </div>

    <div class="detail-actions">
        <button type="button" class="soft-action-btn" data-share-button>
            <i class="fa-solid fa-arrow-up-from-bracket"></i>
            Share
        </button>
        <button
            type="button"
            class="soft-action-btn save-stay-btn <%= isSaved ? 'is-saved' : '' %>"
            data-listing-id="<%= listing._id %>"
            aria-label="Save <%= listing.title %>"
        >
            <i class="<%= isSaved ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
            Save
        </button>
    </div>
</section>

<section class="photo-showcase">
    <div class="photo-main">
        <img src="<%= photoSlots[0] %>" alt="<%= listing.title %>">
    </div>
    <div class="photo-stack">
        <img src="<%= photoSlots[1] %>" alt="<%= listing.title %> interior view">
        <img src="<%= photoSlots[2] %>" alt="<%= listing.title %> nearby view">
    </div>
    <div class="photo-stack">
        <img src="<%= photoSlots[3] %>" alt="<%= listing.title %> stay detail">
        <button type="button" class="show-photos-btn">
            <i class="fa-solid fa-grip"></i>
            <% if (extraPhotoCount > 0) { %>
                +<%= extraPhotoCount %> more photo<%= extraPhotoCount === 1 ? '' : 's' %>
            <% } else { %>
                Show all photos
            <% } %>
        </button>
    </div>
</section>

<div class="detail-layout">
    <main class="detail-main">
        <section class="host-summary">
            <div>
                <h2>Entire place hosted by
                    <% if (listing.owner && listing.owner.username) { %>
                        <a href="/users/<%= listing.owner._id %>" class="host-link"><%= hostName %></a>
                    <% } else { %>
                        <%= hostName %>
                    <% } %>
                </h2>
                <p><%= guests %> guest<%= guests === 1 ? '' : 's' %> · <%= bedrooms %> bedroom<%= bedrooms === 1 ? '' : 's' %> · 1 bath</p>
            </div>
            <div class="host-avatar-block">
                <div class="host-avatar">
                    <i class="fa-solid fa-circle-user"></i>
                </div>
                <% if (currUser && listing.owner && !currUser._id.equals(listing.owner._id)) { %>
                    <a href="/listings/<%= listing._id %>/message" class="btn btn-sm btn-outline-dark">
                        <i class="fa-regular fa-comment-dots"></i> Message host
                    </a>
                <% } %>
            </div>
        </section>

        <section class="standout-grid">
            <article>
                <i class="fa-solid fa-medal"></i>
                <div>
                    <h3>Guest favorite style</h3>
                    <p>A highly polished stay page with ratings, highlights, and saved stays.</p>
                </div>
            </article>

            <article>
                <i class="fa-solid fa-door-open"></i>
                <div>
                    <h3>Easy arrival</h3>
                    <p>Self check-in details and arrival expectations are clear before booking.</p>
                </div>
            </article>

            <article>
                <i class="fa-solid fa-calendar-days"></i>
                <div>
                    <h3>Book with confidence</h3>
                    <p>The reservation panel calculates nights, fees, taxes, and total price.</p>
                </div>
            </article>
        </section>

        <section class="description-block">
            <h2>About this stay</h2>
            <p><%= listing.description %></p>
        </section>

        <section class="amenities-block">
            <h2>What this place offers</h2>
            <% if (amenities.length) { %>
                <div class="amenities-grid">
                    <% amenities.forEach(amenity => { %>
                        <div>
                            <i class="<%= amenity.icon %>"></i>
                            <span><%= amenity.label %></span>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p class="text-muted">The host hasn't listed amenities for this stay yet.</p>
            <% } %>
        </section>

        <section class="amenities-block">
            <h2>House rules</h2>
            <% if (listing.houseRules && listing.houseRules.length) { %>
                <div class="amenities-grid">
                    <% listing.houseRules.forEach(rule => { %>
                        <div>
                            <i class="fa-solid fa-circle-check"></i>
                            <span><%= rule %></span>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p class="text-muted">The host hasn't listed any specific house rules.</p>
            <% } %>
        </section>

        <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
            <section class="owner-actions">
                <a
                    href="/listings/<%= listing._id %>/edit"
                    class="btn btn-dark edit-btn"
                >
                    Edit listing
                </a>

                <form
                    method="POST"
                    action="/listings/<%= listing._id %>?_method=DELETE"
                >
                    <button class="btn btn-outline-dark">
                        Delete listing
                    </button>
                </form>
            </section>
        <% } %>

        <section class="reviews-section">
            <div class="section-heading-row">
                <h2>
                    <i class="fa-solid fa-star"></i>
                    <%= averageRating %> · <%= reviewCount %> reviews
                </h2>
            </div>

            <% if(currUser) { %>
                <form
                    action="/listings/<%= listing.id %>/reviews"
                    method="POST"
                    novalidate
                    class="needs-validation review-form"
                >
                    <h3>Leave a review</h3>

                    <div class="mb-3">
                        <label for="rating" class="form-label">
                            Rating
                        </label>

                        <fieldset class="starability-slot">
                            <input
                                type="radio"
                                id="no-rate"
                                class="input-no-rate"
                                name="review[rating]"
                                value="1"
                                checked
                            />

                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1">1 star</label>

                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2">2 stars</label>

                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3">3 stars</label>

                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4">4 stars</label>

                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5">5 stars</label>
                        </fieldset>
                    </div>

                    <div class="mb-3">
                        <label for="comment" class="form-label">
                            Comments
                        </label>

                        <textarea
                            id="comment"
                            name="review[comment]"
                            rows="4"
                            class="form-control"
                            required
                        ></textarea>

                        <div class="invalid-feedback">
                            Please enter your comments
                        </div>
                    </div>

                    <button class="btn btn-outline-dark">
                        Submit review
                    </button>
                </form>
            <% } %>

            <div class="reviews-grid">
                <% for(let review of reviews) { %>
                    <%
                        const authorName = review.author && review.author.username
                            ? review.author.username
                            : "guest";
                    %>
                    <article class="review-card">
                        <div class="review-author">
                            <i class="fa-solid fa-circle-user"></i>
                            <div>
                                <h3>@<%= authorName %></h3>
                                <p
                                    class="starability-result"
                                    data-rating="<%= review.rating %>"
                                >
                                    Rated: <%= review.rating %> stars
                                </p>
                            </div>
                        </div>

                        <p><%= review.comment %></p>

                        <% if (review.hostReply && review.hostReply.text) { %>
                            <div class="host-reply">
                                <p class="host-reply-label"><i class="fa-solid fa-reply"></i> Response from <%= hostName %></p>
                                <p><%= review.hostReply.text %></p>
                            </div>
                        <% } else if (currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
                            <form
                                method="POST"
                                action="/listings/<%= listing._id %>/reviews/<%= review._id %>/reply"
                                class="host-reply-form"
                            >
                                <label for="reply-<%= review._id %>" class="form-label">Reply as host</label>
                                <textarea
                                    id="reply-<%= review._id %>"
                                    name="reply[text]"
                                    rows="2"
                                    class="form-control"
                                    required
                                ></textarea>
                                <button class="btn btn-sm btn-outline-dark mt-2">Post reply</button>
                            </form>
                        <% } %>

                        <% if(currUser && review.author && currUser._id.equals(review.author._id)) { %>
                            <form
                                method="POST"
                                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                            >
                                <button class="btn btn-sm btn-outline-dark">
                                    Delete
                                </button>
                            </form>
                        <% } %>
                    </article>
                <% } %>
            </div>
        </section>

        <section class="map-section">
            <h2>Where you'll be</h2>
            <p><%= locationLine %></p>

            <% if (hasCoordinates) { %>
                <div id="map"></div>
            <% } else { %>
                <div class="map-fallback">
                    <i class="fa-solid fa-location-dot"></i>
                    <span>Map coordinates are not available for this listing yet.</span>
                </div>
            <% } %>
        </section>
    </main>

    <aside class="booking-panel">
        <div class="booking-card">
            <div class="booking-card-header">
                <p>
                    <b>&#8377;<%= nightlyPrice.toLocaleString('en-IN') %></b>
                    night
                </p>
                <span>
                    <i class="fa-solid fa-star"></i>
                    <%= averageRating %>
                </span>
            </div>

            <% if(currUser) { %>
                <form
                    id="bookingForm"
                    action="/listings/<%= listing._id %>/book"
                    method="POST"
                    data-nightly-price="<%= nightlyPrice %>"
                    data-unavailable-ranges='<%- JSON.stringify(unavailableRanges) %>'
                >
                    <div class="booking-fields">
                        <label>
                            <span>Check in</span>
                            <input
                                id="checkIn"
                                type="date"
                                name="checkIn"
                                required
                            >
                        </label>

                        <label>
                            <span>Check out</span>
                            <input
                                id="checkOut"
                                type="date"
                                name="checkOut"
                                required
                            >
                        </label>

                        <label class="booking-guests">
                            <span>Guests</span>
                            <input
                                id="guests"
                                type="number"
                                name="guests"
                                min="1"
                                max="<%= guests %>"
                                value="1"
                            >
                        </label>
                    </div>

                    <button class="btn reserve-btn">
                        Reserve
                    </button>

                    <p class="booking-note">You will not be charged yet</p>

                    <div class="price-breakdown">
                        <div>
                            <span>
                                &#8377;<%= nightlyPrice.toLocaleString('en-IN') %> x
                                <span id="nightsLabel">1 night</span>
                            </span>
                            <span id="subtotalAmount">&#8377;<%= nightlyPrice.toLocaleString('en-IN') %></span>
                        </div>
                        <div>
                            <span>WanderLust service fee</span>
                            <span id="serviceFeeAmount">&#8377;<%= serviceFee.toLocaleString('en-IN') %></span>
                        </div>
                        <div>
                            <span>Taxes</span>
                            <span id="taxAmount">&#8377;<%= taxes.toLocaleString('en-IN') %></span>
                        </div>
                        <div class="price-total">
                            <span>Total</span>
                            <span id="bookingTotal">&#8377;<%= oneNightTotal.toLocaleString('en-IN') %></span>
                        </div>
                    </div>
                </form>
            <% } else { %>
                <div class="login-to-book">
                    <p>Please login to book this property.</p>
                    <a href="/login" class="btn reserve-btn">Login to reserve</a>
                </div>
            <% } %>
        </div>

        <% if (unavailableRanges.length > 0) { %>
            <div class="availability-card">
                <h3><i class="fa-regular fa-calendar-xmark"></i> Unavailable dates</h3>
                <ul>
                    <% bookedRangeList.forEach(r => { %>
                        <li><%= fmtDate(r.start) %> &rarr; <%= fmtDate(r.end) %> <span class="text-muted">(booked)</span></li>
                    <% }) %>
                    <% blockedDateList.forEach(b => { %>
                        <li>
                            <%= fmtDate(b.startDate) %> &rarr; <%= fmtDate(b.endDate) %>
                            <span class="text-muted">(blocked<%= b.reason ? ": " + b.reason : "" %>)</span>
                            <% if (isOwnerOfListing) { %>
                                <form method="POST" action="/listings/<%= listing._id %>/block/<%= b._id %>?_method=DELETE" class="inline-unblock-form">
                                    <button type="submit" class="link-btn">Remove</button>
                                </form>
                            <% } %>
                        </li>
                    <% }) %>
                </ul>
            </div>
        <% } %>

        <% if (isOwnerOfListing) { %>
            <div class="availability-card">
                <h3><i class="fa-solid fa-ban"></i> Block dates</h3>
                <p class="text-muted">Keep dates open for maintenance or personal use.</p>
                <form method="POST" action="/listings/<%= listing._id %>/block" class="block-dates-form">
                    <label>
                        <span>From</span>
                        <input type="date" name="startDate" required>
                    </label>
                    <label>
                        <span>To</span>
                        <input type="date" name="endDate" required>
                    </label>
                    <label>
                        <span>Reason (optional)</span>
                        <input type="text" name="reason" placeholder="e.g. Maintenance">
                    </label>
                    <button type="submit" class="btn btn-outline-dark">Block these dates</button>
                </form>
            </div>
        <% } %>
    </aside>
</div>

<% if (hasCoordinates) { %>
    <script>
    function initMap() {
        const coordinates =
            <%- JSON.stringify(listing.geometry.coordinates) %>;

        const location = {
            lat: coordinates[1],
            lng: coordinates[0]
        };

        const map = new google.maps.Map(
            document.getElementById("map"),
            {
                zoom: 12,
                center: location
            }
        );

        new google.maps.Marker({
            position: location,
            map: map
        });
    }
    </script>

    <script
        src="https://maps.googleapis.com/maps/api/js?key=<%= mapToken %>&callback=initMap"
        async
        defer>
    </script>
<% } %>
